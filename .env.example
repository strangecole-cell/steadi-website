# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys or secrets.

# --- Supabase ---
# Project Settings -> API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Server-side only. NEVER expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Tester submission ---
# The universal code testers enter on /testerteam. Server-side check only.
STEADI_TESTER_CODE=your-universal-tester-code

# --- Tremendous ---
TREMENDOUS_API_KEY=your-tremendous-sandbox-api-key
TREMENDOUS_BASE_URL=https://testflight.tremendous.com/api/v2
TREMENDOUS_CAMPAIGN_ID=your-campaign-or-product-id
# sandbox or production — must be explicitly changed to enable real payouts
TREMENDOUS_MODE=sandbox

# --- Admin auth ---
# Single admin login via Supabase Auth. Edge Functions check the logged-in
# user's email against this allow-list of one address.
ADMIN_EMAIL=hello@vitalearthlab.com
# Only needed if a future auth approach requires an additional shared secret.
ADMIN_AUTH_SECRET=
